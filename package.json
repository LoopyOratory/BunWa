{
  "name": "waha-bun",
  "version": "2026.5.1",
  "description": "WhatsApp HTTP API - Bun/Hono Edition with Pro features",
  "type": "module",
  "scripts": {
    "start": "bash scripts/start.sh",
    "dev": "bash scripts/dev.sh",
    "dev:ui": "cd frontend && bun run dev",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "build:frontend": "bash scripts/build-frontend.sh",
    "test": "bun test",
    "lint": "oxlint src/",
    "lint-fix": "oxlint --fix src/",
    "setup": "bun install && bash scripts/build-frontend.sh",
    "dashboard:download": "bash scripts/download-dashboard.sh",
    "dashboard:serve": "cd dashboard && bun run --cwd . serve"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@aws-sdk/client-s3": "^3.633.0",
    "@aws-sdk/s3-request-presigner": "^3.633.0",
    "@casl/ability": "^6.8.0",
    "@figuro/chatwoot-sdk": "^1.1.17",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "async-lock": "^1.4.1",
    "axios": "^1.9.0",
    "axios-retry": "^4.5.0",
    "bullmq": "^5.48.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "hono": "^4.7.0",
    "ioredis": "^5",
    "knex": "^3.2.10",
    "lodash": "^4.17.21",
    "mongodb": "6.9.0",
    "node-cache": "5.1.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^11.2.1",
    "promise-retry": "^2.0.1",
    "qrcode": "^1.5.1",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "sqlite3": "^6.0.1",
    "tsyringe": "^4.8.0",
    "ulid": "^2.3.0",
    "user-agents": "^2.1.91",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash": "^4.14.194",
    "oxlint": "^1.13.0",
    "typescript": "^5.9.2"
  }
}
