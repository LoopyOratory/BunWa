# WAHA Configuration
# Copy this file to .env and edit with your settings

# API Authentication (required — header only, no query param)
WAHA_API_KEY=waha

# Dashboard Credentials
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your-dashboard-password

# Swagger/API Docs Credentials (optional)
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=your-swagger-password

# Server
PORT=3000
WAHA_LOG_LEVEL=info  # debug, info, warn, error

# WhatsApp Engine
WHATSAPP_DEFAULT_ENGINE=NOWEB

# Session Management
WHATSAPP_RESTART_ALL_SESSIONS=false
WHATSAPP_START_SESSION=  # comma-separated session names to auto-start
WAHA_AUTO_START_DELAY_SECONDS=0

# Media
WAHA_STORAGE_TYPE=LOCAL  # LOCAL or S3
WHATSAPP_FILES_FOLDER=./.media
WHATSAPP_DOWNLOAD_MEDIA=true
WHATSAPP_FILES_MIMETYPES=  # comma-separated, empty = all

# Database (bun:sqlite native — high performance)
WAHA_DATABASE_URL=  # PostgreSQL connection string (optional)
WAHA_SQLITE_PATH=.sessions/waha.db

# Session Storage
WHATSAPP_SESSIONS_MONGO_URL=  # MongoDB URL (optional)
WHATSAPP_SESSIONS_POSTGRESQL_URL=  # PostgreSQL URL (optional)

# Webhook (optional — delivers session status, message events)
WAHA_WEBHOOK_URL=

# CORS (optional — when set, enables credentials for that origin)
# Examples: "http://localhost:3000" or "http://a.com,http://b.com"
WAHA_CORS_ORIGIN=

# Proxy (optional)
WHATSAPP_PROXY_SERVER=
WHATSAPP_PROXY_SERVER_LIST=  # comma-separated proxy list
WHATSAPP_PROXY_SERVER_USERNAME=
WHATSAPP_PROXY_SERVER_PASSWORD=

# Session Config
WAHA_SESSION_CONFIG_IGNORE_STATUS=false
WAHA_SESSION_CONFIG_IGNORE_GROUPS=false
WAHA_SESSION_CONFIG_IGNORE_CHANNELS=false
WAHA_SESSION_CONFIG_IGNORE_BROADCAST=false

# Debug
WAHA_DEBUG_MODE=false
DEBUG=  # set to 1 for Baileys debug logs
