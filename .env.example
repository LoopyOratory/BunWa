# =============================================================================
# BunWa — WhatsApp HTTP API Server Configuration
# Copy this file to .env and edit with your settings.
# =============================================================================
#
# Conventions:
#   Variables commented with "(optional)" can be left empty for safe defaults.
#   Boolean values: true, false, 1, 0, yes, no (case-insensitive).
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================

# HTTP port. Takes precedence over WHATSAPP_API_PORT.
# PORT=3000

# Fallback port if PORT is not set.
# WHATSAPP_API_PORT=3000

# URL scheme (http or https).
# WHATSAPP_API_SCHEMA=http

# Server hostname.
# WHATSAPP_API_HOSTNAME=localhost

# Override the auto-generated base URL (schema://hostname:port).
# WAHA_BASE_URL=

# Comma-separated trusted proxy IPs. When set, the rate-limiter reads
# x-forwarded-for headers for client IP detection.
# TRUSTED_PROXIES=

# Comma-separated CORS origins (e.g. "http://localhost:3000" or
# "http://a.com,http://b.com"). When set, credentialed CORS is enabled
# for those origins. Leave empty for wildcard (no credentials).
# WAHA_CORS_ORIGIN=

# =============================================================================
# AUTHENTICATION
# =============================================================================

# API key for programmatic access (header: X-Api-Key) — highly recommended.
# WAHA_API_KEY=

# When false, requests without an API key are rejected.
# Default is true for development convenience; set to false in production.
# WAHA_ALLOW_NO_AUTH=true

# Comma-separated API paths excluded from API key authentication
# (e.g. "/api/health,/api/version").
# WHATSAPP_API_KEY_EXCLUDE_PATH=

# =============================================================================
# DASHBOARD
# =============================================================================

# Enable or disable the web dashboard UI.
# WAHA_DASHBOARD_ENABLED=true

# Dashboard Basic Auth credentials.
# WAHA_DASHBOARD_USERNAME=admin
# WAHA_DASHBOARD_PASSWORD=admin

# =============================================================================
# API DOCS (Swagger / Scalar)
# =============================================================================

# Enable or disable the interactive API documentation at /api-docs.
# WHATSAPP_SWAGGER_ENABLED=true

# API Docs Basic Auth credentials (optional — leave empty for no auth).
# WHATSAPP_SWAGGER_USERNAME=admin
# WHATSAPP_SWAGGER_PASSWORD=

# API Docs page title.
# WHATSAPP_SWAGGER_TITLE=BUNWA - WhatsApp HTTP API

# API Docs description.
# WHATSAPP_SWAGGER_DESCRIPTION=

# External documentation URL shown in the API docs.
# WHATSAPP_SWAGGER_EXTERNAL_DOC_URL=https://bunwa.ekosystems.dev/

# Enable advanced Swagger configuration options.
# WHATSAPP_SWAGGER_CONFIG_ADVANCED=false

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error, fatal.
# WAHA_LOG_LEVEL=info

# HTTP request log level: trace, debug, info, warn, error.
# WAHA_HTTP_LOG_LEVEL=info

# Log output format: PRETTY or JSON.
# WAHA_LOG_FORMAT=PRETTY

# Set to 1 to enable verbose Baileys debug output.
# DEBUG=

# Enable debug mode (extra diagnostics).
# WAHA_DEBUG_MODE=false

# =============================================================================
# WHATSAPP ENGINE
# =============================================================================

# Default WhatsApp engine: NOWEB (Baileys) or WEBJS (whatsapp-web.js).
# WHATSAPP_DEFAULT_ENGINE=NOWEB

# Alternative engine-type override.
# ENGINE_TYPE=

# Namespace prefix for session names (defaults to engine name).
# WAHA_NAMESPACE=
# WAHA_SESSION_NAMESPACE=

# Custom path to Chrome/Chromium binary (required for WEBJS engine).
# CHROME_PATH=
# PUPPETEER_EXECUTABLE_PATH=

# Set to false to suppress QR code output in the console.
# WAHA_PRINT_QR=true

# =============================================================================
# CLIENT CONFIG (NOWEB)
# =============================================================================

# Custom device and browser name shown to WhatsApp (NOWEB engine only).
# WAHA_CLIENT_DEVICE_NAME=
# WAHA_CLIENT_BROWSER_NAME=

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# Comma-separated session names to auto-start on server boot.
# WHATSAPP_START_SESSION=

# When true, restores and starts all previously-running sessions on boot.
# WHATSAPP_RESTART_ALL_SESSIONS=false

# Delay in seconds before auto-starting sessions.
# WAHA_AUTO_START_DELAY_SECONDS=0

# Worker ID for multi-worker deployments.
# WAHA_WORKER_ID=

# When true, the worker restores sessions on start.
# WAHA_WORKER_RESTART_SESSIONS=true

# Version override: CORE or PLUS. Auto-detected if unset.
# WAHA_VERSION=

# =============================================================================
# PRESENCE
# =============================================================================

# Automatically mark session as ONLINE on any message activity.
# WAHA_PRESENCE_AUTO_ONLINE=true

# Duration (in seconds) to keep session ONLINE after activity.
# Default is 25 (matches WhatsApp Web's inactivity timeout).
# WAHA_PRESENCE_AUTO_ONLINE_DURATION_SECONDS=25

# =============================================================================
# SESSION CONFIG — CHAT FILTERING
# =============================================================================

# When true, ignore status/lists messages when loading session data.
# WAHA_SESSION_CONFIG_IGNORE_STATUS=false

# When true, ignore group chats when loading session data.
# WAHA_SESSION_CONFIG_IGNORE_GROUPS=false

# When true, ignore channels when loading session data.
# WAHA_SESSION_CONFIG_IGNORE_CHANNELS=false

# When true, ignore broadcast lists when loading session data.
# WAHA_SESSION_CONFIG_IGNORE_BROADCAST=false

# =============================================================================
# DATABASE
# =============================================================================

# Database driver: sqlite, postgres, or mongo.
# WAHA_DATABASE_DRIVER=sqlite

# SQLite database file path (used when driver is sqlite).
# WAHA_SQLITE_PATH=.sessions/waha.db

# PostgreSQL connection string (required when driver is postgres).
# WAHA_DATABASE_URL=

# Alternative PostgreSQL URL for session storage (alias for WAHA_DATABASE_URL).
# WHATSAPP_SESSIONS_POSTGRESQL_URL=

# MongoDB connection string for session storage.
# WHATSAPP_SESSIONS_MONGO_URL=

# Database type reported in the infrastructure endpoint.
# WAHA_DB_TYPE=sqlite
# WAHA_DB_HOST=localhost
# WAHA_DB_PORT=5432
# WAHA_DB_USERNAME=
# WAHA_DB_NAME=./data/waha.sqlite
# WAHA_DB_SSL=false

# =============================================================================
# MEDIA
# =============================================================================

# Directory for downloaded media files.
# WHATSAPP_FILES_FOLDER=/tmp/whatsapp-files

# Enable or disable automatic media download.
# WHATSAPP_DOWNLOAD_MEDIA=true

# Comma-separated allowed MIME types for download (empty = all allowed).
# WHATSAPP_FILES_MIMETYPES=

# Health check thresholds in MB.
# WHATSAPP_HEALTH_MEDIA_FILES_THRESHOLD_MB=100
# WHATSAPP_HEALTH_SESSION_FILES_THRESHOLD_MB=100

# =============================================================================
# STORAGE — LOCAL
# =============================================================================

# Storage backend: local or s3.
# STORAGE_TYPE=local

# Local path for media file storage.
# STORAGE_LOCAL_PATH=./data/media

# Base directory for session auth data on disk.
# WAHA_LOCAL_STORE_BASE_DIR=.sessions

# Directory for internal databases (audit, templates).
# WAHA_STORAGE_DIR=./data

# General data directory (for export/import operations).
# DATA_DIR=./data

# Maximum number of backup files to retain during export/import.
# EXPORT_IMPORT_MAX_BACKUPS=

# Import limits — per-entry byte cap (default 200 MiB) and max entries.
# STORAGE_IMPORT_MAX_BYTES=209715200
# STORAGE_IMPORT_MAX_ENTRIES=100000

# Days to retain audit logs (default 90; set to 0 or negative to disable).
# AUDIT_RETENTION_DAYS=90

# =============================================================================
# STORAGE — S3
# =============================================================================
# Set STORAGE_TYPE=s3 and configure the vars below.

# S3-compatible endpoint URL (e.g. https://minio.example.com).
# S3_ENDPOINT=

# S3 credentials (canonical names).
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Legacy credential aliases (read as fallback).
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# S3 bucket name.
# S3_BUCKET=waha-bun

# S3 region.
# S3_REGION=us-east-1

# WAHA-prefixed S3 vars (used in the infrastructure endpoint).
# WAHA_S3_ENDPOINT=
# WAHA_S3_BUCKET=
# WAHA_S3_REGION=us-east-1
# WAHA_S3_ACCESS_KEY=
# WAHA_S3_SECRET_KEY=

# =============================================================================
# STORAGE — LEGACY ALIASES
# =============================================================================

# Alternative names read by storage.service.ts for the same values.
# WAHA_STORAGE_TYPE=local
# WAHA_STORAGE_LOCAL_PATH=./data/media

# =============================================================================
# WEBHOOK
# =============================================================================

# Default webhook URL for all sessions (overridable per session).
# WAHA_WEBHOOK_URL=

# Enable or disable SSRF protection for webhook delivery.
# Set to false to allow webhooks to private/internal networks.
# WEBHOOK_SSRF_PROTECT=true

# Comma-separated hostnames/IPs allowed when SSRF protection is enabled.
# SSRF_ALLOWED_HOSTS=

# =============================================================================
# PROXY
# =============================================================================

# Single proxy server for WhatsApp connections (format: protocol://host:port).
# WHATSAPP_PROXY_SERVER=

# Comma-separated list of proxy servers (overrides WHATSAPP_PROXY_SERVER).
# WHATSAPP_PROXY_SERVER_LIST=

# Index prefix for mapping sessions to proxies.
# WHATSAPP_PROXY_SERVER_INDEX_PREFIX=

# Proxy authentication.
# WHATSAPP_PROXY_SERVER_USERNAME=
# WHATSAPP_PROXY_SERVER_PASSWORD=

# =============================================================================
# QUEUE / REDIS
# =============================================================================

# Enable Redis-backed queue for async operations.
# WAHA_QUEUE_ENABLED=false

# Redis connection.
# WAHA_REDIS_HOST=localhost
# WAHA_REDIS_PORT=6379
# WAHA_REDIS_PASSWORD=

# =============================================================================
# MCP (Model Context Protocol)
# =============================================================================

# When true, MCP tools operate in read-only mode.
# MCP_READONLY=false

# MCP rate-limit settings.
# MCP_RATE_LIMIT_MAX=60
# MCP_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# CHATWOOT INTEGRATION
# =============================================================================

# Milo API URL for Chatwoot webhook forwarding.
# MILO_API_URL=http://localhost:3003/api/webhooks/chatwoot/milo

# =============================================================================
# HEALTH CHECK
# =============================================================================

# MongoDB health check timeout in milliseconds.
# WHATSAPP_HEALTH_MONGO_TIMEOUT_MS=3000
